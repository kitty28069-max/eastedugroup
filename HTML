        </div>
        <div class="branch-info">
            <h4>東湖校</h4>
            <p>電話：<a href="tel:02-26306133">02-2630-6133</a></p>
            <p>地址：台北市內湖區康寧路三段174號</p>
        </div>
        <div class="branch-info">
            <h4>麗山校</h4>
            <p>電話：<a href="tel:02-26279528">02-2627-9528</a></p>
            <p>地址：臺北市內湖區內湖路一段629巷45號</p>
        </div>
    </footer>
    <div class="copyright">
        Copyright © 2026 東德教育集團. All rights reserved.
    </div>

    <script>
        // 加入簡單的平滑滾動效果
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
    </script>
</body>
</html>
